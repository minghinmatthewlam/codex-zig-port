# fish completion for codex-zig
complete -c codex-zig -f
complete -c codex-zig -n '__fish_use_subcommand' -a 'a app app-server apply auth-status cloud cloud-tasks completion debug e exec exec-server execpolicy features fork help login logout mcp mcp-server plugin remote-control remote-fork review resume sandbox sessions update'
complete -c codex-zig -n '__fish_seen_subcommand_from completion' -a 'bash elvish fish powershell zsh'
complete -c codex-zig -s h -l help -d 'Print help'
complete -c codex-zig -s V -l version -d 'Print version'
complete -c codex-zig -s p -l profile -r -d 'Select config profile'
complete -c codex-zig -s C -l cd -r -d 'Use working root'
complete -c codex-zig -l add-dir -r -d 'Add writable root'
complete -c codex-zig -s c -l config -r -d 'Override config key'
complete -c codex-zig -s m -l model -r -d 'Override model'
complete -c codex-zig -s i -l image -r -d 'Attach image to first interactive prompt'
complete -c codex-zig -l enable -r -d 'Enable feature for this invocation'
complete -c codex-zig -l disable -r -d 'Disable feature for this invocation'
complete -c codex-zig -l oss -d 'Use local OSS provider'
complete -c codex-zig -l local-provider -xa 'lmstudio ollama' -d 'Select local provider'
complete -c codex-zig -s a -l ask-for-approval -xa 'untrusted on-failure on-request never' -d 'Approval policy'
complete -c codex-zig -l approval-policy -xa 'untrusted on-failure on-request never' -d 'Approval policy'
complete -c codex-zig -s s -l sandbox -xa 'read-only workspace-write danger-full-access' -d 'Sandbox mode'
complete -c codex-zig -l yolo -d 'Disable approvals and sandbox'
complete -c codex-zig -l search -d 'Enable live web search'
complete -c codex-zig -l remote -r -d 'Connect interactive TUI to remote app-server'
complete -c codex-zig -l remote-auth-token-env -r -d 'Read remote app-server token from env'
complete -c codex-zig -l remote-control -d 'Start local remote-control server'
complete -c codex-zig -l remote-control-bind -r -d 'Bind local remote-control server'
complete -c codex-zig -l no-alt-screen -d 'Disable alternate-screen TUI mode'
